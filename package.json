{
  "name": "student-idle-rpg-latest-html",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "serve": "node tools/serve.mjs",
    "preview": "npm run visual:build && node tools/preview.mjs",
    "build:web": "npm run visual:build && node tools/prepare-web.mjs",
    "snapshot:extract": "node tools/snapshot-extract.mjs reference/Student-Idle-RPG-mobile-3.html",
    "snapshot:build": "npm run visual:build && node tools/snapshot-build.mjs",
    "snapshot:verify": "npm run snapshot:build && npm run verify:mobile",
    "patch:career-outcome": "node tools/apply-career-outcome-patch.mjs",
    "patch:retake-year": "node tools/apply-retake-year-patch.mjs",
    "patch:visual-assets": "node tools/apply-visual-asset-patch.mjs",
    "patch:battle-road": "node tools/apply-battle-road-patch.mjs",
    "battle-road:verify": "node tools/validate-battle-road-config.mjs",
    "visual:build": "npm run patch:visual-assets && npm run patch:battle-road && node tools/sync-character-animation-manifest.mjs && python tools/prepare-character-sprites.py && python tools/generate-professional-sprite-sources.py && python tools/prepare-professional-sprites.py && node tools/build-visual-assets.mjs",
    "visual:audit": "node tools/visual-asset-audit.mjs",
    "visual:sheet": "node tools/visual-asset-contact-sheet.mjs",
    "visual:verify": "node tools/verify-visual-assets.mjs && npm run visual:audit",
    "visual:smoke": "node tools/visual-asset-smoke.mjs",
    "live:polish": "node tools/live-visual-polish-check.mjs",
    "visual:qa": "npm run build:web && npm run visual:verify && npm run visual:sheet && npm run visual:smoke",
    "asset:factory": "node tools/asset-factory/run.mjs",
    "asset:factory:prepare": "node tools/asset-factory/run.mjs prepare",
    "asset:factory:review": "node tools/asset-factory/run.mjs review",
    "asset:factory:qa": "node tools/asset-factory/run.mjs qa",
    "asset:factory:doctor": "node tools/asset-factory/run.mjs doctor",
    "asset:factory:install-skill": "node tools/asset-factory/run.mjs install-skill",
    "asset:integrity": "python tools/asset-factory/audit-sprite-integrity.py",
    "balance:verify": "node tools/validate-career-balance.mjs",
    "career:smoke": "node tools/career-outcome-smoke.mjs",
    "retake:smoke": "node tools/retake-year-smoke.mjs",
    "audit": "node tools/audit-reference.mjs",
    "extract:data": "node tools/extract-reference-data.mjs",
    "extract:bundle": "node tools/extract-bundle.mjs",
    "reference:refresh": "npm run audit && npm run extract:data && npm run extract:bundle",
    "verify": "npm run balance:verify && npm run battle-road:verify && npm run audit && npm run snapshot:build && npm run visual:verify",
    "mobile:smoke": "node tools/mobile-smoke.mjs",
    "verify:mobile": "npm run verify && npm run build:web && npm run mobile:smoke && npm run visual:smoke && npm run career:smoke && npm run retake:smoke",
    "cap:add:android": "npm run build:web && cap add android",
    "cap:sync": "npm run build:web && cap sync android",
    "cap:open": "cap open android",
    "android:install-jdk": "powershell -ExecutionPolicy Bypass -File tools/install-portable-jdk.ps1",
    "android:setup-sdk": "powershell -ExecutionPolicy Bypass -File tools/setup-android-sdk.ps1",
    "android:doctor": "cap doctor android",
    "android:debug": "node tools/build-android.mjs debug",
    "android:release": "node tools/build-android.mjs release"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@playwright/test": "^1.61.0"
  }
}
