{
  "version": 1,
  "description": "학생탭 공격 VFX에 사용할 학년별 교과 토큰 매핑 테이블입니다. 런타임은 공격 1회마다 현재 학년의 토큰 풀에서 1개를 선택해 표시합니다.",
  "selection": {
    "mode": "random_one_per_attack",
    "tokensPerAttack": 1,
    "source": "current_grade_weighted_pool",
    "repeatWindow": 3,
    "seedHint": ["gradeOrder", "battleId", "targetId", "attackSerial"],
    "help": {
      "mode": "공격 1회에 표시할 토큰 선택 방식입니다.",
      "tokensPerAttack": "공격 1회에 동시에 표시되는 교과 토큰 수입니다. 현재 기준은 1개입니다.",
      "source": "현재 학년의 가중치 토큰 풀에서 선택한다는 의미입니다.",
      "repeatWindow": "향후 런타임에서 같은 토큰 반복을 피할 때 참고할 최근 선택 개수입니다.",
      "seedHint": "결정적 랜덤 선택이 필요할 때 사용할 수 있는 상태 키 후보입니다."
    }
  },
  "runtime": {
    "renderer": "dom_text_layer",
    "skinKey": "default",
    "localizationKeyPrefix": "curriculum.attackVfx",
    "tokenKeyStrategy": "grade_pool_token",
    "help": {
      "renderer": "교과 공격 VFX 토큰을 어떤 렌더러로 표시할지 정합니다. 현재는 고정 DOM 텍스트 레이어를 사용합니다.",
      "skinKey": "향후 스킨별 색상, 질감, 모션 프리셋을 분기할 때 사용할 기본 스킨 키입니다.",
      "localizationKeyPrefix": "향후 언어별 토큰 테이블이나 번역 키를 만들 때 사용할 키 prefix입니다.",
      "tokenKeyStrategy": "향후 토큰 문자열 대신 안정적인 로컬라이제이션 키를 생성할 때 사용할 키 구성 방식입니다."
    }
  },
  "rules": {
    "maxTokenChars": 8,
    "minPoolsPerGrade": 3,
    "minTokensPerPool": 4,
    "allowedSubjects": ["korean", "english", "math", "science", "social", "exam", "habit"],
    "inquirySubjectAliases": {
      "social": ["science"],
      "science": ["social"]
    },
    "help": {
      "maxTokenChars": "모바일 전투장에서 글자가 겹치지 않도록 한 토큰의 최대 글자 수를 제한합니다.",
      "minPoolsPerGrade": "학년별로 최소 몇 개의 과목/테마 풀이 있어야 하는지 정합니다.",
      "minTokensPerPool": "각 토큰 풀이 최소 몇 개의 후보를 가져야 하는지 정합니다.",
      "allowedSubjects": "토큰 풀이 사용할 수 있는 과목/테마 id 목록입니다.",
      "inquirySubjectAliases": "사회/과학 탐구처럼 같은 탐구 계열로 묶어 토큰 풀을 함께 참고할 과목 alias입니다."
    }
  },
  "styles": [
    {
      "id": "glyph",
      "label": "낱글자",
      "renderer": "text",
      "motion": "pop_arc",
      "description": "짧은 글자, 숫자, 알파벳이 튀어나가며 타격 지점으로 이동합니다."
